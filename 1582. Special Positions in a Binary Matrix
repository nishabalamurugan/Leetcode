class Solution:
    def numSpecial(self, mat: List[List[int]]) -> int:
        count=0
        for i in range(len(mat)):
            row=[]
            for j in range(0,len(mat[0])):
                row=mat[i]
                col=[]
                for k in range(len(mat)):
                    col.append(mat[k][j])
                #print(mat[i][j],row,col,row.count(1),col.count(1))
                if(mat[i][j]==1 and row.count(1)==1 and col.count(1)==1):
                    count+=1
            #print()
        return count
        
