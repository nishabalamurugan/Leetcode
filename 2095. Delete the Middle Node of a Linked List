# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def deleteMiddle(self, head: Optional[ListNode]) -> Optional[ListNode]:
        if not head.next:
            return None
        length=0 
        temp=head
        while(temp!= None):
            length+=1
            temp=temp.next
        mid=length//2 
        temp2=head
        for i in range(mid-1):
            temp2=temp2.next
        temp2.next=temp2.next.next
        return head
        
