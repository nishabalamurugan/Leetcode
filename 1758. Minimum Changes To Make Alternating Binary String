class Solution:
    def minOperations(self, s: str) -> int:
        even_count=0
        odd_count=0
        #01010101
        #10101010
        even_pattern='01'*100000
        odd_pattern='10'*1000000
        for i in range(len(s)):
            #even_pattern
            if(i%2==0):
                if (s[i]=='1'):
                    even_count+=1            
            else:
                if(s[i]=='0'):
                    even_count+=1
            #odd_pattern
            if(i%2!=0):
                if(s[i]!='0'):
                    odd_count+=1
            else:
                if(s[i]!='1'):
                    odd_count+=1
        return min(even_count,odd_count)
        
